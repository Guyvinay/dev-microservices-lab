<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- To enable auditing -->
    <changeSet id="113" author="vinay.singh">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="AUTH_REVINFO_TABLE"/>
            </not>
        </preConditions>
        <createTable tableName="AUTH_REVINFO_TABLE">
            <column name="ID" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="TIMESTAMP" type="BIGINT"/>
            <column name="MODIFIEDBY" type="varchar(150)"/>
        </createTable>
    </changeSet>

    <changeSet id="118" author="vinay.singh" context="dev,prod" labels="feature1,feature2">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="test_table"/>
            </not>
        </preConditions>
        <createTable tableName="test_table">
            <column name="test_id" type="int">
                <constraints primaryKey="true"/>
            </column>
            <column name="test_column" type="INT"/>
        </createTable>
        <comment>test table created</comment>
    </changeSet>



    <changeSet id="14:03:2026-02:04-create-space-table" author="vinay">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="space"/>
            </not>
        </preConditions>

        <createTable tableName="space">

            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="description" type="VARCHAR(255)"/>

            <column name="created_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>

        </createTable>

    </changeSet>

    <changeSet id="14:03:2026-02:04-create-field-type-table" author="vinay">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="field_type"/>
            </not>
        </preConditions>

        <createTable tableName="field_type">

            <column name="id" type="VARCHAR(50)">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="created_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>

        </createTable>

    </changeSet>


    <changeSet id="14:03:2026-02:04-create-field-definition-table" author="vinay">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="field_definition"/>
            </not>
        </preConditions>

        <createTable tableName="field_definition">

            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="space_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="field_type_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="label" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="description" type="TEXT"/>

            <column name="ui" type="TEXT"/>

            <column name="validation" type="TEXT"/>

            <column name="created_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>

        </createTable>
    </changeSet>


    <changeSet id="14:03:2026-02:04-create-form-table" author="vinay">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="space_form"/>
            </not>
        </preConditions>

        <createTable tableName="space_form">

            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="space_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="description" type="TEXT"/>

            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>

        </createTable>
    </changeSet>


    <changeSet id="14:03:2026-02:04-create-form-field-definition-table" author="vinay">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="form_field_definition"/>
            </not>
        </preConditions>

        <createTable tableName="form_field_definition">

            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="form_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="field_definition_id" type="UUID">
                <constraints nullable="false"/>
            </column>

            <column name="display_order" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="label_override" type="VARCHAR(255)"/>

            <column name="description_override" type="TEXT"/>

            <column name="ui_override" type="TEXT"/>

            <column name="validation_override" type="TEXT"/>

            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="TIMESTAMPTZ">
                <constraints nullable="false"/>
            </column>

        </createTable>
    </changeSet>


</databaseChangeLog>